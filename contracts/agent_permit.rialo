// AgentPermit v4 — Multi-sig, Delegation, Role-based Policy Scopes, Staking/Slashing, Timelock
// Compile with Rialo CDK ^0.11.2+. Uses AFTER timer pattern for expiry and timelock execution.
workflow {
  state {
    // --- Core ---
    owner: Address,
    globally_paused: bool,

    // --- Agents & Delegation ---
    agents: Map<Bytes32, Agent>,
    delegations: Map<Bytes32, Delegation>,

    // --- Policies & Roles ---
    policies: Map<Bytes32, Policy>,
    roles: Map<Bytes32, Role>,
    policy_roles: Map<Bytes32, Bytes32>, // policy_id -> role_id

    // --- Permits ---
    permits: Map<Bytes32, Permit>,

    // --- Multi-sig Approvals ---
    guardians: Map<Address, bool>,
    approvals: Map<Bytes32, Approval>,
    guardian_votes: Map<Bytes32, Map<Address, bool>>,

    // --- Staking & Slashing ---
    stakes: Map<Bytes32, Stake>,
    slash_records: Map<Bytes32, SlashRecord>,

    // --- Receipts & Credentials ---
    receipts: Map<Bytes32, Receipt>,
    credential_hashes: Map<Bytes32, Bytes32>,

    // --- Timelock ---
    timelock_delay: u64,
    pending_admin_actions: Map<Bytes32, PendingAction>,

    // --- Policy Migration ---
    policy_migrations: Map<Bytes32, PolicyMigration>,

    // --- Rialo Cruise: Gas-less Meta-Transactions ---
    meta_tx_nonces: Map<Address, u64>,       // per-signer nonce to prevent replay
    meta_tx_relayer: Address,                 // authorized relayer (Permitly backend)
    sponsored_permits: Map<Bytes32, bool>,    // permits paid for by relayer
    cruise_budget: u128,                      // total RIALO allocated for gas sponsorship
    cruise_spent: u128                        // gas spent so far
  }

  // ============================================================
  // Structs
  // ============================================================

  struct Agent {
    controller: Address,
    active: bool,
    role_id: Bytes32,
    staked_amount: u128,
    violation_count: u32
  }

  struct Delegation {
    delegate: Address,
    agent_id: Bytes32,
    scope_root: Bytes32,
    expires_at: u64,
    active: bool
  }

  struct Policy {
    policy_hash: Bytes32,
    version: u32,
    active: bool,
    min_approvals: u8,       // N-of-M: minimum guardian approvals required
    requires_timelock: bool  // if true, admin actions on this policy need timelock
  }

  struct Role {
    name: Bytes32,           // role name hash (e.g. "admin", "auditor", "operator")
    scope_root: Bytes32,     // merkle root of allowed scopes for this role
    max_budget: u128,        // max total budget across all permits for this role
    max_per_action: u128,    // max per-action limit
    can_delegate: bool,
    can_approve: bool,
    active: bool
  }

  struct Permit {
    agent_id: Bytes32,
    policy_id: Bytes32,
    role_id: Bytes32,
    scope_root: Bytes32,
    budget_cap: u128,
    max_per_action: u128,
    spent: u128,
    expires_at: u64,
    status: u8,              // 1=active, 2=revoked, 3=expired, 4=frozen
    policy_version: u32
  }

  struct Approval {
    permit_id: Bytes32,
    action_hash: Bytes32,
    amount: u128,
    status: u8,              // 1=pending, 2=approved, 3=denied, 4=expired
    required_votes: u8,
    yes_votes: u8,
    no_votes: u8,
    created_at: u64,
    expires_at: u64
  }

  struct Stake {
    agent_id: Bytes32,
    amount: u128,
    locked_until: u64,
    status: u8               // 1=active, 2=locked, 3=slashed, 4=withdrawn
  }

  struct SlashRecord {
    agent_id: Bytes32,
    amount: u128,
    reason: Bytes32,
    receipt_id: Bytes32,
    created_at: u64
  }

  struct Receipt {
    permit_id: Bytes32,
    action_hash: Bytes32,
    amount: u128,
    result: u8,              // 1=authorized, 2=denied_budget, 3=denied_scope, 4=denied_policy, 5=denied_stake
    previous_hash: Bytes32,
    created_at: u64
  }

  struct PendingAction {
    action_hash: Bytes32,
    target_fn: Bytes32,
    params_hash: Bytes32,
    created_at: u64,
    executes_at: u64,
    executed: bool
  }

  struct PolicyMigration {
    from_version: u32,
    to_version: u32,
    new_policy_id: Bytes32,
    effective_at: u64,
    completed: bool
  }

  // ============================================================
  // Events
  // ============================================================
  event AgentRegistered(agent_id: Bytes32, controller: Address, role_id: Bytes32);
  event AgentDeactivated(agent_id: Bytes32);
  event AgentRoleChanged(agent_id: Bytes32, old_role: Bytes32, new_role: Bytes32);
  event DelegationCreated(delegation_id: Bytes32, agent_id: Bytes32, delegate: Address, expires_at: u64);
  event DelegationRevoked(delegation_id: Bytes32);
  event PolicyPublished(policy_id: Bytes32, policy_hash: Bytes32, version: u32, min_approvals: u8);
  event PolicyDeprecated(policy_id: Bytes32);
  event RoleCreated(role_id: Bytes32, name: Bytes32, scope_root: Bytes32);
  event RoleUpdated(role_id: Bytes32, scope_root: Bytes32);
  event PermitIssued(permit_id: Bytes32, agent_id: Bytes32, policy_id: Bytes32, role_id: Bytes32, expires_at: u64);
  event PermitFrozen(permit_id: Bytes32);
  event PermitUnfrozen(permit_id: Bytes32);
  event PermitRevoked(permit_id: Bytes32);
  event PermitExpired(permit_id: Bytes32);
  event PermitMigrated(permit_id: Bytes32, old_policy: Bytes32, new_policy: Bytes32);
  event ApprovalRequested(approval_id: Bytes32, permit_id: Bytes32, action_hash: Bytes32, amount: u128, required_votes: u8);
  event VoteCast(approval_id: Bytes32, guardian: Address, approved: bool);
  event ApprovalDecided(approval_id: Bytes32, approved: bool, yes_votes: u8, no_votes: u8);
  event GuardianAdded(guardian: Address);
  event GuardianRemoved(guardian: Address);
  event StakeDeposited(agent_id: Bytes32, amount: u128);
  event StakeWithdrawn(agent_id: Bytes32, amount: u128);
  event StakeSlashed(agent_id: Bytes32, amount: u128, reason: Bytes32);
  event ActionAuthorized(receipt_id: Bytes32, permit_id: Bytes32, action_hash: Bytes32, amount: u128);
  event ActionDenied(receipt_id: Bytes32, permit_id: Bytes32, result: u8);
  event CredentialRegistered(credential_id: Bytes32, metadata_hash: Bytes32);
  event EmergencyStop(incident_hash: Bytes32, timestamp: u64);
  event EmergencyResume(resolution_hash: Bytes32, timestamp: u64);
  event TimelockScheduled(action_id: Bytes32, executes_at: u64);
  event TimelockExecuted(action_id: Bytes32);
  event TimelockCancelled(action_id: Bytes32);
  event PolicyMigrationStarted(migration_id: Bytes32, policy_id: Bytes32, from_version: u32, to_version: u32);
  event PolicyMigrationCompleted(migration_id: Bytes32);
  // --- Rialo Cruise events ---
  event MetaTxRelayed(relayer: Address, signer: Address, nonce: u64, kind: Bytes32);
  event CruiseBudgetSet(budget: u128);
  event CruiseBudgetSpent(amount: u128, remaining: u128);
  event RelayerSet(relayer: Address);
  event SponsoredPermitIssued(permit_id: Bytes32, sponsored_by: Address);

  // ============================================================
  // Modifier helpers
  // ============================================================
  fn only_owner(self) {
    assert(self.sender == self.owner);
  }

  fn only_guardian(self) {
    assert(self.guardians.get(self.sender) == true);
  }

  fn only_relayer(self) {
    assert(self.sender == self.meta_tx_relayer);
  }

  fn not_paused(self) {
    assert(!self.globally_paused);
  }

  // ============================================================
  // Admin: Ownership & Guardians
  // ============================================================

  fn transfer_ownership(self, new_owner: Address) {
    self.only_owner();
    assert(new_owner != Address::default());
    self.owner = new_owner;
  }

  fn add_guardian(self, guardian: Address) {
    self.only_owner();
    assert(guardian != Address::default());
    assert(self.guardians.get(guardian) != true);
    self.guardians.insert(guardian, true);
    emit GuardianAdded(guardian);
  }

  fn remove_guardian(self, guardian: Address) {
    self.only_owner();
    assert(self.guardians.get(guardian) == true);
    self.guardians.remove(guardian);
    emit GuardianRemoved(guardian);
  }

  fn set_timelock_delay(self, delay: u64) {
    self.only_owner();
    assert(delay >= 60); // minimum 60 seconds
    self.timelock_delay = delay;
  }

  // ============================================================
  // Rialo Cruise: Gas-less Transaction Management
  // ============================================================

  /// Set the authorized relayer (Permitly backend) that submits meta-txs
  fn set_relayer(self, relayer: Address) {
    self.only_owner();
    assert(relayer != Address::default());
    self.meta_tx_relayer = relayer;
    emit RelayerSet(relayer);
  }

  /// Set the total cruise budget (RIALO allocated for gas sponsorship)
  fn set_cruise_budget(self, budget: u128) {
    self.only_owner();
    self.cruise_budget = budget;
    self.cruise_spent = 0;
    emit CruiseBudgetSet(budget);
  }

  /// Verify an off-chain signed meta-transaction payload.
  /// Checks: relayer authorization, nonce freshness, and budget availability.
  fn verify_meta_tx(self, signer: Address, nonce: u64, kind: Bytes32) -> bool {
    self.only_relayer();
    // Check nonce: must be exactly next expected nonce for this signer
    let expected_nonce = self.meta_tx_nonces.get(signer);
    assert(nonce == expected_nonce);
    // Check cruise budget
    assert(self.cruise_spent < self.cruise_budget);
    return true;
  }

  /// Consume a nonce after a meta-tx is processed (prevents replay)
  fn consume_nonce(self, signer: Address) {
    let current = self.meta_tx_nonces.get(signer);
    self.meta_tx_nonces.insert(signer, current + 1);
  }

  /// Record cruise gas spending
  fn record_cruise_spend(self, amount: u128) {
    self.cruise_spent = self.cruise_spent + amount;
    emit CruiseBudgetSpent(amount, self.cruise_budget - self.cruise_spent);
  }

  // ============================================================
  // Sponsored Permit Issuance (Relayer pays gas)
  // ============================================================

  /// Issue a permit sponsored by the relayer — user doesn't need RIALO
  fn sponsored_issue_permit(
    self,
    permit_id: Bytes32,
    agent_id: Bytes32,
    policy_id: Bytes32,
    scope_root: Bytes32,
    budget_cap: u128,
    max_per_action: u128,
    expires_at: u64,
    signer: Address,
    nonce: u64,
    gas_amount: u128
  ) {
    self.only_relayer();
    self.not_paused();
    assert(self.verify_meta_tx(signer, nonce, "sponsored_issue_permit"));
    assert(expires_at > block.timestamp);
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    assert(agent.controller == signer);
    let policy = self.policies.get(policy_id);
    assert(policy.active);
    let role = self.roles.get(agent.role_id);
    assert(role.active);
    assert(budget_cap <= role.max_budget);
    assert(max_per_action <= role.max_per_action);

    self.permits.insert(permit_id, Permit {
      agent_id,
      policy_id,
      role_id: agent.role_id,
      scope_root,
      budget_cap,
      max_per_action,
      spent: 0,
      expires_at,
      status: 1,
      policy_version: policy.version
    });
    self.sponsored_permits.insert(permit_id, true);
    self.consume_nonce(signer);
    self.record_cruise_spend(gas_amount);
    emit PermitIssued(permit_id, agent_id, policy_id, agent.role_id, expires_at);
    emit SponsoredPermitIssued(permit_id, self.sender);
    AFTER wait until block.timestamp >= expires_at Do self.expire_permit(permit_id);
  }

  /// Authorize an action with gas paid by the relayer
  fn sponsored_authorize(
    self,
    permit_id: Bytes32,
    action_hash: Bytes32,
    scope_proof: Bytes,
    amount: u128,
    receipt_id: Bytes32,
    previous_hash: Bytes32,
    signer: Address,
    nonce: u64,
    gas_amount: u128
  ) -> bool {
    self.only_relayer();
    self.not_paused();
    assert(self.verify_meta_tx(signer, nonce, "sponsored_authorize"));

    let permit = self.permits.get(permit_id);
    assert(permit.status == 1);
    assert(block.timestamp < permit.expires_at);

    let agent = self.agents.get(permit.agent_id);
    assert(agent.active);
    let is_controller = agent.controller == signer;
    let is_delegate = false;
    if (!is_controller) {
      for each (delegation_id, delegation) in self.delegations {
        if delegation.active && delegation.delegate == signer && delegation.agent_id == permit.agent_id {
          assert(block.timestamp < delegation.expires_at);
          assert(verify_merkle(scope_proof, action_hash, delegation.scope_root));
          is_delegate = true;
          break;
        }
      }
      assert(is_delegate);
    }

    let policy = self.policies.get(permit.policy_id);
    assert(policy.active);
    assert(verify_merkle(scope_proof, action_hash, permit.scope_root));
    assert(amount <= permit.max_per_action);
    assert(permit.spent + amount <= permit.budget_cap);

    // Check staking if applicable
    let stake = self.stakes.get(permit.agent_id);
    if stake.status == 1 {
      assert(stake.amount >= amount / 10);
    }

    permit.spent = permit.spent + amount;
    self.permits.insert(permit_id, permit);

    self.receipts.insert(receipt_id, Receipt {
      permit_id,
      action_hash,
      amount,
      result: 1,
      previous_hash,
      created_at: block.timestamp
    });
    self.consume_nonce(signer);
    self.record_cruise_spend(gas_amount);
    emit ActionAuthorized(receipt_id, permit_id, action_hash, amount);
    return true;
  }

  /// Record a denial with gas paid by the relayer
  fn sponsored_record_denial(
    self,
    permit_id: Bytes32,
    action_hash: Bytes32,
    receipt_id: Bytes32,
    previous_hash: Bytes32,
    result: u8,
    signer: Address,
    nonce: u64,
    gas_amount: u128
  ) {
    self.only_relayer();
    assert(result == 2 || result == 3 || result == 4 || result == 5);
    assert(self.verify_meta_tx(signer, nonce, "sponsored_record_denial"));

    self.receipts.insert(receipt_id, Receipt {
      permit_id,
      action_hash,
      amount: 0,
      result,
      previous_hash,
      created_at: block.timestamp
    });
    self.consume_nonce(signer);
    self.record_cruise_spend(gas_amount);
    emit ActionDenied(receipt_id, permit_id, result);
  }

  // ============================================================
  // Agents & Delegation
  // ============================================================

  fn register_agent(self, agent_id: Bytes32, controller: Address, role_id: Bytes32) {
    self.only_owner();
    assert(self.roles.get(role_id).active);
    self.agents.insert(agent_id, Agent {
      controller,
      active: true,
      role_id,
      staked_amount: 0,
      violation_count: 0
    });
    emit AgentRegistered(agent_id, controller, role_id);
  }

  fn deactivate_agent(self, agent_id: Bytes32) {
    self.only_owner();
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    agent.active = false;
    self.agents.insert(agent_id, agent);
    emit AgentDeactivated(agent_id);
  }

  fn set_agent_role(self, agent_id: Bytes32, new_role_id: Bytes32) {
    self.only_owner();
    assert(self.roles.get(new_role_id).active);
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    let old_role = agent.role_id;
    agent.role_id = new_role_id;
    self.agents.insert(agent_id, agent);
    emit AgentRoleChanged(agent_id, old_role, new_role_id);
  }

  fn create_delegation(self, delegation_id: Bytes32, agent_id: Bytes32, delegate: Address, scope_root: Bytes32, expires_at: u64) {
    self.not_paused();
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    assert(agent.controller == self.sender || self.sender == self.owner);
    let role = self.roles.get(agent.role_id);
    assert(role.can_delegate);
    assert(expires_at > block.timestamp);
    self.delegations.insert(delegation_id, Delegation {
      delegate,
      agent_id,
      scope_root,
      expires_at,
      active: true
    });
    emit DelegationCreated(delegation_id, agent_id, delegate, expires_at);
  }

  fn revoke_delegation(self, delegation_id: Bytes32) {
    let delegation = self.delegations.get(delegation_id);
    assert(delegation.active);
    let agent = self.agents.get(delegation.agent_id);
    assert(agent.controller == self.sender || self.sender == self.owner);
    delegation.active = false;
    self.delegations.insert(delegation_id, delegation);
    emit DelegationRevoked(delegation_id);
  }

  // ============================================================
  // Roles
  // ============================================================

  fn create_role(self, role_id: Bytes32, name: Bytes32, scope_root: Bytes32, max_budget: u128, max_per_action: u128, can_delegate: bool, can_approve: bool) {
    self.only_owner();
    self.roles.insert(role_id, Role {
      name,
      scope_root,
      max_budget,
      max_per_action,
      can_delegate,
      can_approve,
      active: true
    });
    emit RoleCreated(role_id, name, scope_root);
  }

  fn update_role(self, role_id: Bytes32, scope_root: Bytes32, max_budget: u128, max_per_action: u128, can_delegate: bool, can_approve: bool) {
    self.only_owner();
    let role = self.roles.get(role_id);
    assert(role.active);
    role.scope_root = scope_root;
    role.max_budget = max_budget;
    role.max_per_action = max_per_action;
    role.can_delegate = can_delegate;
    role.can_approve = can_approve;
    self.roles.insert(role_id, role);
    emit RoleUpdated(role_id, scope_root);
  }

  fn deactivate_role(self, role_id: Bytes32) {
    self.only_owner();
    let role = self.roles.get(role_id);
    assert(role.active);
    role.active = false;
    self.roles.insert(role_id, role);
  }

  // ============================================================
  // Policies
  // ============================================================

  fn publish_policy(self, policy_id: Bytes32, policy_hash: Bytes32, version: u32, role_id: Bytes32, min_approvals: u8, requires_timelock: bool) {
    self.only_owner();
    assert(self.roles.get(role_id).active);
    self.policies.insert(policy_id, Policy {
      policy_hash,
      version,
      active: true,
      min_approvals,
      requires_timelock
    });
    self.policy_roles.insert(policy_id, role_id);
    emit PolicyPublished(policy_id, policy_hash, version, min_approvals);
  }

  fn deprecate_policy(self, policy_id: Bytes32) {
    self.only_owner();
    let policy = self.policies.get(policy_id);
    assert(policy.active);
    policy.active = false;
    self.policies.insert(policy_id, policy);
    emit PolicyDeprecated(policy_id);
  }

  fn start_policy_migration(self, migration_id: Bytes32, policy_id: Bytes32, new_policy_id: Bytes32, effective_at: u64) {
    self.only_owner();
    let old_policy = self.policies.get(policy_id);
    assert(old_policy.active);
    let new_policy = self.policies.get(new_policy_id);
    assert(new_policy.active);
    assert(new_policy.version > old_policy.version);
    assert(effective_at > block.timestamp);
    self.policy_migrations.insert(migration_id, PolicyMigration {
      from_version: old_policy.version,
      to_version: new_policy.version,
      new_policy_id,
      effective_at,
      completed: false
    });
    emit PolicyMigrationStarted(migration_id, policy_id, old_policy.version, new_policy.version);
  }

  // ============================================================
  // Permits
  // ============================================================

  fn issue_permit(self, permit_id: Bytes32, agent_id: Bytes32, policy_id: Bytes32, scope_root: Bytes32, budget_cap: u128, max_per_action: u128, expires_at: u64) {
    self.only_owner();
    self.not_paused();
    assert(expires_at > block.timestamp);
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    let policy = self.policies.get(policy_id);
    assert(policy.active);
    let role = self.roles.get(agent.role_id);
    assert(role.active);
    assert(budget_cap <= role.max_budget);
    assert(max_per_action <= role.max_per_action);

    self.permits.insert(permit_id, Permit {
      agent_id,
      policy_id,
      role_id: agent.role_id,
      scope_root,
      budget_cap,
      max_per_action,
      spent: 0,
      expires_at,
      status: 1,
      policy_version: policy.version
    });
    emit PermitIssued(permit_id, agent_id, policy_id, agent.role_id, expires_at);
    AFTER wait until block.timestamp >= expires_at Do self.expire_permit(permit_id);
  }

  fn migrate_permit(self, permit_id: Bytes32, migration_id: Bytes32) {
    self.only_owner();
    let permit = self.permits.get(permit_id);
    assert(permit.status == 1);
    let migration = self.policy_migrations.get(migration_id);
    assert(!migration.completed);
    assert(block.timestamp >= migration.effective_at);
    let old_policy_id = permit.policy_id;
    permit.policy_id = migration.new_policy_id;
    permit.policy_version = migration.to_version;
    self.permits.insert(permit_id, permit);
    emit PermitMigrated(permit_id, old_policy_id, migration.new_policy_id);
  }

  fn complete_policy_migration(self, migration_id: Bytes32) {
    self.only_owner();
    let migration = self.policy_migrations.get(migration_id);
    assert(!migration.completed);
    migration.completed = true;
    self.policy_migrations.insert(migration_id, migration);
    emit PolicyMigrationCompleted(migration_id);
  }

  fn freeze_permit(self, permit_id: Bytes32) {
    self.only_owner();
    let permit = self.permits.get(permit_id);
    assert(permit.status == 1);
    permit.status = 4;
    self.permits.insert(permit_id, permit);
    emit PermitFrozen(permit_id);
  }

  fn unfreeze_permit(self, permit_id: Bytes32) {
    self.only_owner();
    let permit = self.permits.get(permit_id);
    assert(permit.status == 4);
    permit.status = 1;
    self.permits.insert(permit_id, permit);
    emit PermitUnfrozen(permit_id);
  }

  fn revoke_permit(self, permit_id: Bytes32) {
    self.only_owner();
    let permit = self.permits.get(permit_id);
    permit.status = 2;
    self.permits.insert(permit_id, permit);
    emit PermitRevoked(permit_id);
  }

  // ============================================================
  // Authorization with Multi-sig & Staking
  // ============================================================

  fn authorize_and_consume(self, permit_id: Bytes32, action_hash: Bytes32, scope_proof: Bytes, amount: u128, receipt_id: Bytes32, previous_hash: Bytes32) -> bool {
    self.not_paused();
    let permit = self.permits.get(permit_id);
    assert(permit.status == 1);
    assert(block.timestamp < permit.expires_at);

    let agent = self.agents.get(permit.agent_id);
    assert(agent.active);
    let is_controller = agent.controller == self.sender;
    let is_delegate = false;
    if (!is_controller) {
      for each (delegation_id, delegation) in self.delegations {
        if delegation.active && delegation.delegate == self.sender && delegation.agent_id == permit.agent_id {
          assert(block.timestamp < delegation.expires_at);
          assert(verify_merkle(scope_proof, action_hash, delegation.scope_root));
          is_delegate = true;
          break;
        }
      }
      assert(is_delegate);
    }

    let policy = self.policies.get(permit.policy_id);
    assert(policy.active);
    assert(verify_merkle(scope_proof, action_hash, permit.scope_root));
    assert(amount <= permit.max_per_action);
    assert(permit.spent + amount <= permit.budget_cap);

    let stake = self.stakes.get(permit.agent_id);
    if stake.status == 1 {
      assert(stake.amount >= amount / 10);
    }

    permit.spent = permit.spent + amount;
    self.permits.insert(permit_id, permit);

    self.receipts.insert(receipt_id, Receipt {
      permit_id,
      action_hash,
      amount,
      result: 1,
      previous_hash,
      created_at: block.timestamp
    });
    emit ActionAuthorized(receipt_id, permit_id, action_hash, amount);
    return true;
  }

  // ============================================================
  // Multi-sig Approvals
  // ============================================================

  fn request_approval(self, approval_id: Bytes32, permit_id: Bytes32, action_hash: Bytes32, amount: u128) {
    self.not_paused();
    let permit = self.permits.get(permit_id);
    assert(permit.status == 1);
    let agent = self.agents.get(permit.agent_id);
    assert(agent.controller == self.sender);

    let policy = self.policies.get(permit.policy_id);
    let required = policy.min_approvals;
    assert(required > 0);

    let guardian_count: u8 = 0;
    for each (addr, is_guardian) in self.guardians {
      if is_guardian { guardian_count = guardian_count + 1; }
    }
    assert(guardian_count >= required);

    self.approvals.insert(approval_id, Approval {
      permit_id,
      action_hash,
      amount,
      status: 1,
      required_votes: required,
      yes_votes: 0,
      no_votes: 0,
      created_at: block.timestamp,
      expires_at: block.timestamp + 86400
    });
    emit ApprovalRequested(approval_id, permit_id, action_hash, amount, required);
  }

  fn cast_vote(self, approval_id: Bytes32, approved: bool) {
    self.only_guardian();
    let approval = self.approvals.get(approval_id);
    assert(approval.status == 1);
    assert(block.timestamp < approval.expires_at);

    let votes = self.guardian_votes.get(approval_id);
    assert(votes.get(self.sender) != true);

    votes.insert(self.sender, true);
    self.guardian_votes.insert(approval_id, votes);

    if approved {
      approval.yes_votes = approval.yes_votes + 1;
    } else {
      approval.no_votes = approval.no_votes + 1;
    }

    emit VoteCast(approval_id, self.sender, approved);

    if approval.yes_votes >= approval.required_votes {
      approval.status = 2;
      self.approvals.insert(approval_id, approval);
      emit ApprovalDecided(approval_id, true, approval.yes_votes, approval.no_votes);
    } else if approval.no_votes >= approval.required_votes {
      approval.status = 3;
      self.approvals.insert(approval_id, approval);
      emit ApprovalDecided(approval_id, false, approval.yes_votes, approval.no_votes);
    } else {
      self.approvals.insert(approval_id, approval);
    }
  }

  fn expire_approval(self, approval_id: Bytes32) {
    let approval = self.approvals.get(approval_id);
    if approval.status == 1 && block.timestamp >= approval.expires_at {
      approval.status = 4;
      self.approvals.insert(approval_id, approval);
    }
  }

  // ============================================================
  // Staking & Slashing
  // ============================================================

  fn deposit_stake(self, agent_id: Bytes32, amount: u128) {
    self.not_paused();
    let agent = self.agents.get(agent_id);
    assert(agent.active);
    assert(agent.controller == self.sender);
    assert(amount > 0);

    let stake = self.stakes.get(agent_id);
    if stake.status == 0 || stake.status == 4 {
      self.stakes.insert(agent_id, Stake {
        agent_id,
        amount,
        locked_until: block.timestamp + 2592000,
        status: 1
      });
    } else {
      assert(stake.status == 1);
      stake.amount = stake.amount + amount;
      self.stakes.insert(agent_id, stake);
    }

    agent.staked_amount = agent.staked_amount + amount;
    self.agents.insert(agent_id, agent);
    emit StakeDeposited(agent_id, amount);
  }

  fn withdraw_stake(self, agent_id: Bytes32) {
    let stake = self.stakes.get(agent_id);
    assert(stake.status == 1);
    assert(block.timestamp >= stake.locked_until);

    let agent = self.agents.get(agent_id);
    assert(agent.controller == self.sender);

    stake.status = 4;
    self.stakes.insert(agent_id, stake);
    agent.staked_amount = 0;
    self.agents.insert(agent_id, agent);
    emit StakeWithdrawn(agent_id, stake.amount);
  }

  fn slash_stake(self, agent_id: Bytes32, slash_id: Bytes32, amount: u128, reason: Bytes32, receipt_id: Bytes32) {
    self.only_owner();
    let stake = self.stakes.get(agent_id);
    assert(stake.status == 1);
    assert(amount <= stake.amount);
    assert(amount > 0);

    stake.amount = stake.amount - amount;
    if stake.amount == 0 {
      stake.status = 3;
    }
    self.stakes.insert(agent_id, stake);

    let agent = self.agents.get(agent_id);
    agent.staked_amount = stake.amount;
    agent.violation_count = agent.violation_count + 1;
    self.agents.insert(agent_id, agent);

    self.slash_records.insert(slash_id, SlashRecord {
      agent_id,
      amount,
      reason,
      receipt_id,
      created_at: block.timestamp
    });

    emit StakeSlashed(agent_id, amount, reason);
  }

  // ============================================================
  // Timelocked Admin Actions
  // ============================================================

  fn schedule_timelock_action(self, action_id: Bytes32, target_fn: Bytes32, params_hash: Bytes32) {
    self.only_owner();
    assert(self.timelock_delay > 0);
    let executes_at = block.timestamp + self.timelock_delay;
    self.pending_admin_actions.insert(action_id, PendingAction {
      action_hash: sha256(action_id ++ target_fn ++ params_hash),
      target_fn,
      params_hash,
      created_at: block.timestamp,
      executes_at,
      executed: false
    });
    emit TimelockScheduled(action_id, executes_at);
  }

  fn execute_timelock_action(self, action_id: Bytes32) {
    self.only_owner();
    let action = self.pending_admin_actions.get(action_id);
    assert(!action.executed);
    assert(block.timestamp >= action.executes_at);
    action.executed = true;
    self.pending_admin_actions.insert(action_id, action);
    emit TimelockExecuted(action_id);
  }

  fn cancel_timelock_action(self, action_id: Bytes32) {
    self.only_owner();
    let action = self.pending_admin_actions.get(action_id);
    assert(!action.executed);
    action.executed = true;
    self.pending_admin_actions.insert(action_id, action);
    emit TimelockCancelled(action_id);
  }

  // ============================================================
  // Credentials
  // ============================================================

  fn register_credential_hash(self, credential_id: Bytes32, metadata_hash: Bytes32) {
    self.only_owner();
    self.credential_hashes.insert(credential_id, metadata_hash);
    emit CredentialRegistered(credential_id, metadata_hash);
  }

  // ============================================================
  // Denial Recording
  // ============================================================

  fn record_denial(self, permit_id: Bytes32, action_hash: Bytes32, receipt_id: Bytes32, previous_hash: Bytes32, result: u8) {
    assert(result == 2 || result == 3 || result == 4 || result == 5);
    self.receipts.insert(receipt_id, Receipt {
      permit_id,
      action_hash,
      amount: 0,
      result,
      previous_hash,
      created_at: block.timestamp
    });
    emit ActionDenied(receipt_id, permit_id, result);
  }

  // ============================================================
  // Emergency Controls
  // ============================================================

  fn emergency_stop(self, incident_hash: Bytes32) {
    self.only_owner();
    self.globally_paused = true;
    emit EmergencyStop(incident_hash, block.timestamp);
  }

  fn emergency_resume(self, resolution_hash: Bytes32) {
    self.only_owner();
    self.globally_paused = false;
    emit EmergencyResume(resolution_hash, block.timestamp);
  }

  // ============================================================
  // Timers
  // ============================================================

  fn expire_permit(self, permit_id: Bytes32) {
    let permit = self.permits.get(permit_id);
    if permit.status == 1 && block.timestamp >= permit.expires_at {
      permit.status = 3;
      self.permits.insert(permit_id, permit);
      emit PermitExpired(permit_id);
    }
  }
}
